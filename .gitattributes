# Fins de ligne normalisées en LF dans le dépôt.
# INDISPENSABLE : les scripts .sh tournent sur le Pi (Linux) ; des fins CRLF (Windows)
# les casseraient ("bad interpreter"). On force donc LF pour tout le texte.
* text=auto eol=lf

*.sh   text eol=lf
*.py   text eol=lf
*.js   text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.json text eol=lf
